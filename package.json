{
  "name": "my-nestjs-vue",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "pnpm --filter @my-nestjs-vue/web build && pnpm --filter @my-nestjs-vue/server build",
    "dev": "pnpm --parallel --stream --filter @my-nestjs-vue/server --filter @my-nestjs-vue/web run dev",
    "start": "pnpm build && pnpm --filter @my-nestjs-vue/server start",
    "dev:server": "pnpm --filter @my-nestjs-vue/server start:dev",
    "dev:web": "pnpm --filter @my-nestjs-vue/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @my-nestjs-vue/server typecheck && pnpm --filter @my-nestjs-vue/web typecheck"
  }
}
