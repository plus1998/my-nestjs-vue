# --- Basic ---
NODE_ENV=development
PORT=3000

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=my_app_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=super_secret_key_change_me
JWT_EXPIRES_IN=7d

# --- BullMQ ---
QUEUE_PREFIX=my_app_queue
