# --- Web ---
VITE_API_BASE_URL=http://localhost:3000

# --- Server basic ---
NODE_ENV=development
PORT=3000

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=my_app_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
